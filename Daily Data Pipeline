name: Daily Data Pipeline

on:
  schedule:
    - cron: '0 18 * * *' # JST 03:00
  workflow_dispatch:

jobs:
  daily-pipeline:
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          if [ -f requirements.txt ]; then
            pip install -r requirements.txt
          else
            echo "requirements.txt が無いため最小構成でインストールします"
            pip install requests beautifulsoup4 pyyaml supabase python-dotenv pandas numpy statsmodels scikit-learn
          fi

      - name: Collect inventory data from CarSensor
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: |
          if [ -f scripts/collect_inventory.py ]; then
            python scripts/collect_inventory.py
          elif [ -f carsensor_inventory_collector.py ]; then
            python carsensor_inventory_collector.py
          else
            echo "在庫取得スクリプトが見つかりません"
            exit 1
          fi

      - name: Collect weather data
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: |
          if [ -f scripts/collect_weather.py ]; then
            python scripts/collect_weather.py
          else
            echo "scripts/collect_weather.py が未作成のためスキップします"
          fi

      - name: Run regression analysis
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: |
          if [ -f scripts/run_regression.py ]; then
            python scripts/run_regression.py
          else
            echo "scripts/run_regression.py が未作成のためスキップします"
          fi

      - name: Export AI analysis package
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
        run: |
          if [ -f scripts/export_ai_package.py ]; then
            python scripts/export_ai_package.py
          else
            echo "scripts/export_ai_package.py が未作成のためスキップします"
          fi

      - name: Upload export artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: daily-exports
          path: |
            exports/
            output/
          if-no-files-found: ignore

      - name: Notify on failure
        if: failure()
        run: echo "❌ Daily pipeline failed at $(date -u)"
