"""
============================================================
llm_client.py — LLM呼び出し共通モジュール
============================================================
配置場所: app/components/llm_client.py

役割:
  - プロンプトテンプレートの読み込み (config/prompts.yaml)
  - DBデータのフォーマット → プロンプトへの埋め込み
  - LLM APIの呼び出し
  - レスポンスの整形・返却

呼び出し元:
  [A] scripts/generate_insights.py  ← GitHub Actions日次バッチ
  [B] app/pages/03_ai_insights.py   ← Streamlit画面の手動実行ボタン
"""

import os
import yaml
import json
from datetime import date, timedelta
from typing import Optional, Dict, Any


# ============================================================
#  プロンプトテンプレート読み込み
# ============================================================
def load_prompt_template(
    config_path: str = "config/prompts.yaml",
    prompt_key: str = "daily_insight"
) -> Dict[str, str]:
    """
    prompts.yaml からプロンプトテンプレートを読み込む

    Returns:
        {"system": "...", "user_template": "..."}
    """
    with open(config_path, 'r', encoding='utf-8') as f:
        config = yaml.safe_load(f)

    if prompt_key not in config:
        raise KeyError(f"プロンプトキー '{prompt_key}' が見つかりません")

    return config[prompt_key]


# ============================================================
#  DBデータ → プロンプト用テキスト変換
# ============================================================
def format_inventory_data(records: list) -> str:
    """在庫データをテキストテーブルに変換"""
    if not records:
        return "データなし"
    lines = ["| 日付 | 店舗名 | 在庫台数 |", "|------|--------|----------|"]
    for r in records:
        lines.append(f"| {r['date']} | {r['source_name']} | {r['inventory_count']}台 |")
    return "\n".join(lines)


def format_weather_data(records: list) -> str:
    """気象データをテキストテーブルに変換"""
    if not records:
        return "データなし"
    lines = ["| 日付 | 天気 | 最高気温 | 最低気温 | 降水量 |",
             "|------|------|----------|----------|--------|"]
    for r in records:
        lines.append(
            f"| {r['date']} | {r.get('weather','?')} | "
            f"{r.get('temperature_max','?')}℃ | "
            f"{r.get('temperature_min','?')}℃ | "
            f"{r.get('precipitation','?')}mm |"
        )
    return "\n".join(lines)


def format_sales_data(records: list) -> str:
    """実績データをテキストテーブルに変換"""
    if not records:
        return "データなし"
    lines = ["| 日付 | 来場数 | 成約台数 |", "|------|--------|----------|"]
    for r in records:
        visitors = r.get('visitors', '未入力')
        lines.append(f"| {r['date']} | {visitors} | {r['contracts']}台 |")
    return "\n".join(lines)


def format_promotion_data(records: list) -> str:
    """販促費データをテキストテーブルに変換"""
    if not records:
        return "データなし"
    lines = ["| 日付 | 媒体 | 金額 |", "|------|------|------|"]
    for r in records:
        ptype = r.get('promotion_type', '不明')
        lines.append(f"| {r['date']} | {ptype} | ¥{r['promotion_cost']:,.0f} |")
    return "\n".join(lines)


# ============================================================
#  プロンプト組み立て
# ============================================================
def build_prompt(
    store_name: str,
    inventory_records: list,
    weather_records: list,
    sales_records: list,
    promotion_records: list,
    competitor_records: list,
    trade_area_info: str = "未取得",
    weather_forecast: str = "未取得",
    config_path: str = "config/prompts.yaml",
) -> Dict[str, str]:
    """
    全データを結合してプロンプトを組み立てる

    Returns:
        {"system": "...", "user": "完成したプロンプト"}
    """
    template = load_prompt_template(config_path, "daily_insight")

    user_prompt = template["user_template"].format(
        store_name=store_name,
        analysis_date=date.today().isoformat(),
        inventory_data=format_inventory_data(inventory_records),
        weather_data=format_weather_data(weather_records),
        sales_data=format_sales_data(sales_records),
        promotion_data=format_promotion_data(promotion_records),
        competitor_data=format_inventory_data(competitor_records),
        trade_area_data=trade_area_info,
        weather_forecast=weather_forecast,
    )

    return {
        "system": template["system"],
        "user": user_prompt,
    }


# ============================================================
#  LLM API 呼び出し
# ============================================================
def call_llm(
    system_prompt: str,
    user_prompt: str,
    model: str = "gpt-4o-mini",
    max_tokens: int = 2000,
) -> str:
    """
    LLM APIを呼び出してインサイトを生成

    対応モデル:
      - "gpt-4o-mini"    → OpenAI
      - "claude-3-5-sonnet" → Anthropic
      - "gemini-1.5-flash"  → Google

    Returns:
        LLMの回答テキスト
    """

    if model.startswith("gpt"):
        return _call_openai(system_prompt, user_prompt, model, max_tokens)
    elif model.startswith("claude"):
        return _call_anthropic(system_prompt, user_prompt, model, max_tokens)
    elif model.startswith("gemini"):
        return _call_gemini(system_prompt, user_prompt, model, max_tokens)
    else:
        raise ValueError(f"未対応モデル: {model}")


def _call_openai(system: str, user: str, model: str, max_tokens: int) -> str:
    """OpenAI API呼び出し"""
    from openai import OpenAI
    client = OpenAI(api_key=os.environ["OPENAI_API_KEY"])

    response = client.chat.completions.create(
        model=model,
        messages=[
            {"role": "system", "content": system},
            {"role": "user",   "content": user},
        ],
        max_tokens=max_tokens,
        temperature=0.3,  # 分析は低めの温度で安定性重視
    )
    return response.choices[0].message.content


def _call_anthropic(system: str, user: str, model: str, max_tokens: int) -> str:
    """Anthropic Claude API呼び出し"""
    import anthropic
    client = anthropic.Anthropic(api_key=os.environ["ANTHROPIC_API_KEY"])

    response = client.messages.create(
        model=model,
        max_tokens=max_tokens,
        system=system,
        messages=[
            {"role": "user", "content": user},
        ],
        temperature=0.3,
    )
    return response.content[0].text


def _call_gemini(system: str, user: str, model: str, max_tokens: int) -> str:
    """Google Gemini API呼び出し"""
    import google.generativeai as genai
    genai.configure(api_key=os.environ["GOOGLE_API_KEY"])

    gen_model = genai.GenerativeModel(
        model_name=model,
        system_instruction=system,
    )
    response = gen_model.generate_content(
        user,
        generation_config=genai.types.GenerationConfig(
            max_output_tokens=max_tokens,
            temperature=0.3,
        ),
    )
    return response.text


# ============================================================
#  統合関数（メインエントリポイント）
# ============================================================
def generate_daily_insight(
    store_name: str,
    inventory_records: list,
    weather_records: list,
    sales_records: list,
    promotion_records: list,
    competitor_records: list,
    trade_area_info: str = "未取得",
    weather_forecast: str = "未取得",
    llm_model: str = "gpt-4o-mini",
    config_path: str = "config/prompts.yaml",
) -> str:
    """
    日次AIインサイト生成のメインエントリポイント

    1. 全データをフォーマットしてプロンプトを組み立て
    2. LLM APIを呼び出し
    3. インサイトテキストを返却
    """
    prompt = build_prompt(
        store_name=store_name,
        inventory_records=inventory_records,
        weather_records=weather_records,
        sales_records=sales_records,
        promotion_records=promotion_records,
        competitor_records=competitor_records,
        trade_area_info=trade_area_info,
        weather_forecast=weather_forecast,
        config_path=config_path,
    )

    insight = call_llm(
        system_prompt=prompt["system"],
        user_prompt=prompt["user"],
        model=llm_model,
    )

    return insight
